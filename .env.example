# ═══════════════════════════════════════════════════════════
# VARIÁVEIS DE AMBIENTE - CAMMUS LP
# ═══════════════════════════════════════════════════════════
#
# Este arquivo documenta as variáveis necessárias para rodar
# o projeto em desenvolvimento e produção.
#
# DESENVOLVIMENTO (local):
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores reais
#   3. Execute: node backend/server.js
#
# PRODUÇÃO (Vercel):
#   Configure estas variáveis no dashboard da Vercel:
#   Settings → Environment Variables
#
# ═══════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────
# 🔐 WEBHOOK N8N (OBRIGATÓRIO)
# ───────────────────────────────────────────────────────────

# URL completa do webhook N8N para receber leads
# Exemplo: https://n8n.seudominio.com/webhook/abc123
WEBHOOK_URL=https://n8n.example.com/webhook/your-webhook-id

# Token de autenticação do webhook N8N
# Este token é enviado no header X-Webhook-Token
# Gere um token forte: openssl rand -base64 32
WEBHOOK_TOKEN=seu-token-secreto-aqui

# ───────────────────────────────────────────────────────────
# 🌐 CORS (OPCIONAL)
# ───────────────────────────────────────────────────────────

# URLs permitidas para fazer requisições à API
# Em produção, defina o domínio específico para segurança
# Múltiplos domínios: separe com vírgula
# Exemplo: https://cammus.com.br,https://www.cammus.com.br
# Padrão: * (permite qualquer origem)
FRONTEND_URL=*

# ───────────────────────────────────────────────────────────
# ⚙️ CONFIGURAÇÃO DO SERVIDOR (APENAS DESENVOLVIMENTO LOCAL)
# ───────────────────────────────────────────────────────────

# Porta do servidor backend local (backend/server.js)
# A Vercel ignora esta variável (usa serverless functions)
PORT=3000

# Ambiente de execução
# Valores: development | production
# A Vercel define automaticamente como production
NODE_ENV=development

# ───────────────────────────────────────────────────────────
# 📊 RATE LIMITING (OPCIONAL - AVANÇADO)
# ───────────────────────────────────────────────────────────

# Se você implementar rate limiting server-side com Upstash Redis:
# UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=seu-token-upstash

# ═══════════════════════════════════════════════════════════
# INSTRUÇÕES PARA DEPLOY NA VERCEL
# ═══════════════════════════════════════════════════════════
#
# 1. Acesse: https://vercel.com/dashboard
# 2. Selecione seu projeto: cammus-lp
# 3. Vá em: Settings → Environment Variables
# 4. Adicione as seguintes variáveis:
#
#    Nome                  Valor                              Ambiente
#    ─────────────────────────────────────────────────────────────────
#    WEBHOOK_URL          https://n8n.seu.com/webhook/id     Production
#    WEBHOOK_TOKEN        seu-token-secreto                   Production
#    FRONTEND_URL         https://cammus.com.br              Production (opcional)
#
# 5. Clique em "Save"
# 6. Faça um novo deploy (Deployments → Redeploy)
#
# ═══════════════════════════════════════════════════════════
