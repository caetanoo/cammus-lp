# ═══════════════════════════════════════════════════════════
# CAMMUS BACKEND - TEMPLATE DE CONFIGURAÇÃO
# ═══════════════════════════════════════════════════════════
# INSTRUÇÕES:
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores reais no arquivo .env
# 3. NUNCA commite o arquivo .env no Git
# ═══════════════════════════════════════════════════════════

# Token de autenticação do webhook N8N
# Obtenha este token com o time de backend/DevOps
WEBHOOK_TOKEN=seu_token_aqui

# URL do webhook (ambiente de desenvolvimento)
WEBHOOK_URL=https://webhook.dev.exemplo.com/webhook/lead-analysis

# URL do webhook (ambiente de produção)
# WEBHOOK_URL=https://webhook.prod.exemplo.com/webhook/lead-analysis

# Porta do servidor backend
PORT=3000

# Ambiente (development ou production)
NODE_ENV=development

# URL do frontend (para configuração de CORS)
FRONTEND_URL=*
